{
  "Kestrel": {
    "Port": 9000,
    "UseReverseProxy": false,
    "KeepAliveTimeout": 60,
    "RequestHeadersTimeout": 60,
    "Endpoints": {
      "Http": {
        "Url": "http://*:11000"
      },
      "Https": {
        "Url": "https://*:11001"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SharedDb": ""
  },
  "HealthChecks": {
    "IntervalSeconds": 60,
    "PgSql": [
      "Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=<password>"
    ],
    "Tcp": [
      {
        "Name": "localhost",
        "Port": "9000",
        "Description": "self"
      }
    ]
  },
  "HttpPolicies": {
    "OverallTimeout": 30,
    "TimeoutPerTry": 3,
    "RetriesCount": 10
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Observability": {
    "ServiceName": "SALT.WebApi.Template",
    "EnableOtlpExporter": true,
    "EnablePrometheusExporter": false,
    "EnableConsoleExporter": false
  }
}
