<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>Salt.Microservices.Templates</id>
        <version>2.0.0</version>
        <description>Modern dotnet new templates for production-ready ASP.NET Core microservices with OpenAPI, observability, security checks, static analysis, CI/CD scripts, and test projects.</description>
        <authors>Zhivov Oleg A.</authors>
        <owners>Zhivov Oleg A.</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <license type="expression">MIT</license>
        <repository type="git" url="https://github.com/ZhivovOleg/AspCoreTemplates.git"
            branch="master" />
        <dependencies>
            <group targetFramework="net10.0" />
        </dependencies>
    </metadata>
    <files>
        <file src="**"
            exclude="SALT.Core.Templates.csproj;.gitignore;**\bin\**;**\obj\**;**\.idea\**;**\.git\**;**\.github\**;.vscode" />
    </files>
</package>

<!-- create package (powershell) 
dotnet pack -c Release -o .\ -p:NuspecFile=Salt.Core.Templates.nuspec
-p:NuspecProperties="version=$(Get-Date -Format 'yyyy.MMdd.HHmm')"
-->
